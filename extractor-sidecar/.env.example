# OpenRouter (required for successful /extract)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional OpenRouter attribution
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_X_TITLE=

PORT=3000
EXTRACT_MAX_LENGTH=512000
EXTRACT_MAX_JSON_BODY_BYTES=2097152
EXTRACT_OPENROUTER_TIMEOUT_MS=115000

# Redis LLM cache (logical DB 1 recommended in full stack)
REDIS_URL=redis://redis:6379/1
EXTRACT_CACHE_ENABLED=true
EXTRACT_CACHE_TTL_SECONDS=86400
