# SearXNG Configuration
# Copy this file to .env and customize these values

### Required: Core configuration
SEARXNG_PROTOCOL=http
SEARXNG_HOST=localhost
SEARXNG_PORT=7777
SEARXNG_BASE_URL=${SEARXNG_PROTOCOL}://${SEARXNG_HOST}:${SEARXNG_PORT}/
SEARXNG_SECRET_KEY=supersecretkey
###

### Secondary Services
SEARXNG_MCP_PORT=7778
# Streamable HTTP MCP (web mode; REST mirror stays on same port)
# MCP_STREAMABLE_PATH=/mcp
# MCP_STREAMABLE_ENABLED=true
# MCP_STATELESS_HTTP=true
# MCP_JSON_RESPONSE=true
###

### Extract tool (MCP fetch + LLM sidecar)
# Full stack (docker-compose): enabled by default; set false for sidecar-less minimal stacks.
EXTRACT_ENABLED=true
EXTRACTOR_SIDECAR_URL=http://extractor-sidecar:3000
EXTRACT_TIMEOUT=120
EXTRACT_MAX_LENGTH=524288
EXTRACT_MAX_JSON_BODY_BYTES=524288
# Sidecar only — set in .env for OpenRouter (never required on searxng-mcp)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EXTRACT_OPENROUTER_TIMEOUT_MS=115000
REDIS_URL=redis://redis:6379/1
EXTRACT_CACHE_ENABLED=true
EXTRACT_CACHE_TTL_SECONDS=86400
###

### Misc
###
